export component ProjectorWindow inherits Window {
    no-frame: true;
    always-on-top: true;
    title: "";
    background: root.bg_color;

    in property <string> texto_proyeccion: "";
    in property <string> referencia: "";
    in property <float> tamano_letra: 85;
    in property <color> bg_color: black;
    in property <color> text_color: white;
    in property <image> fondo_imagen;
    in property <bool> mostrar_imagen: false;

    if (root.mostrar_imagen) : Image {
        source: root.fondo_imagen;
        width: 100%; height: 100%;
        image-fit: cover;
    }
    if (root.mostrar_imagen) : Rectangle {
        width: 100%; height: 100%;
        background: rgba(0, 0, 0, 0.4);
    }

    VerticalLayout {
        padding: 50px;
        padding-bottom: root.referencia != "" ? 16px : 50px;
        spacing: 0px;

        // Área principal — ocupa TODO el espacio disponible
        Rectangle {
            vertical-stretch: 1;
            background: transparent;
            Text {
                text: root.texto_proyeccion;
                color: root.text_color;
                font-size: root.tamano_letra * 1px;
                font-weight: 900;
                wrap: word-wrap;
                horizontal-alignment: center;
                vertical-alignment: center;
                width: parent.width;
                height: parent.height;
            }
        }

        // Referencia — tamaño proporcional al texto
        if (root.referencia != "") : Rectangle {
            height: root.tamano_letra * 0.55px + 20px;
            background: transparent;
            Text {
                text: root.referencia;
                color: root.text_color;
                font-size: root.tamano_letra * 0.42px;
                font-weight: 800;
                font-italic: true;
                horizontal-alignment: right;
                vertical-alignment: center;
                width: parent.width;
                height: parent.height;
            }
        }
    }
}
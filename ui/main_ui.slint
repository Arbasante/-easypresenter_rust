import { VerticalBox, HorizontalBox, ScrollView, ComboBox, Slider } from "std-widgets.slint";
import { ProjectorWindow } from "projector_ui.slint";
import "./fonts/Inter-VariableFont_opsz,wght.ttf";
export { ProjectorWindow }
import { LineEdit, Button, TextEdit, CheckBox } from "std-widgets.slint";

import "./fonts/GoogleSans-Regular.ttf";
import "./fonts/GoogleSans-Medium.ttf";
import "./fonts/GoogleSans-Bold.ttf";

import "./fonts/Inter-Regular.ttf";
import "./fonts/Inter-Medium.ttf";
import "./fonts/Inter-Bold.ttf";

export struct Canto { id: int, titulo: string, letra: string }
export struct BookInfo { id: int, nombre: string, capitulos: int }
export struct DiapositivaUI { orden: string, texto: string, font_size: float }
export struct ChapterRow { caps: [int] }
export struct MediaItem { id: int, nombre: string, path: string, img: image, aspecto: string, is_loop: bool, }

// ─────────────────────────────────────────────────────────────
//  TAB BUTTON (nuevo componente para la barra de navegación)
// ─────────────────────────────────────────────────────────────
component TabButton inherits Rectangle {
    in property <string> text;
    in property <string> icon; // se mantiene la propiedad por compatibilidad, no se usa visualmente
    in property <bool> active: false;
    callback clicked;

    background: root.active ? rgba(14, 165, 233, 0.10) : (touch.has-hover ? rgba(255,255,255,0.03) : transparent);
    touch := TouchArea { clicked => { root.clicked(); } }

    Text {
        text: root.text; font-size: 9px; font-weight: 800; letter-spacing: 0.4px;
        horizontal-alignment: center; vertical-alignment: center;
        width: 100%; height: 100%;
        color: root.active ? #0ea5e9 : (touch.has-hover ? #9ca3af : #4b5563);
    }

    // Indicador inferior activo
    Rectangle {
        y: parent.height - 2px; height: 2px; width: 100%;
        background: root.active ? #0ea5e9 : transparent;
    }
}

// ─────────────────────────────────────────────────────────────
//  COMPONENTES PERSONALIZADOS (sin cambios)
// ─────────────────────────────────────────────────────────────
component MenuItem inherits Rectangle {
    in property <string> text;
    in property <string> icon;
    in property <bool> has_submenu: false;
    in property <color> text_color: #e5e7eb;
    in property <color> icon_color: #9ca3af;
    callback clicked();

    height: 32px;
    border-radius: 4px;
    background: touch.has-hover ? rgba(255, 255, 255, 0.05) : transparent;

    touch := TouchArea { clicked => { root.clicked(); } }

    HorizontalLayout {
        padding-left: 10px; padding-right: 10px; spacing: 10px;
        alignment: space-between;
        HorizontalLayout {
            spacing: 8px;
            Text { text: root.icon; color: touch.has-hover ? white : root.icon_color; font-size: 14px; vertical-alignment: center; }
            Text { text: root.text; color: touch.has-hover ? white : root.text_color; font-size: 11px; vertical-alignment: center; font-weight: 600; }
        }
        if (root.has_submenu) : Text { text: ">"; color: touch.has-hover ? white : #9ca3af; font-size: 11px; vertical-alignment: center; font-weight: 600; }
    }
}



// ─────────────────────────────────────────────────────────────
//  APP WINDOW
// ─────────────────────────────────────────────────────────────
export component AppWindow inherits Window {
    min-width: 800px; min-height: 600px; background: #18181b; default-font-family: "Google Sans";

    in-out property <string> active-tab: "cantos";
    in property <[Canto]> cantos: [];
    in-out property <string> buscador_texto: "";
    in-out property <string> elemento_seleccionado: "";
    in-out property <[DiapositivaUI]> estrofas_actuales: [];
    in-out property <int> active_estrofa_index: -1;
    in-out property <length> scroll_to_y: 0px;

    in-out property <bool> mostrar_personalizar: false;
    in-out property <string> modal_tab: "biblias";
    callback sync_estilos();
    callback sync_font_scale();  // solo actualiza tamano_letra, sin tocar fondos

    in-out property <string> biblias_bg_type: "negro";
    in-out property <color> biblias_font_color: white;
    in-out property <image> biblias_bg_image;
    in-out property <bool> biblias_has_image: false;
    in-out property <float> biblias_fondo_opacity: 0.0;
    in-out property <float> biblias_font_scale: 1.0;

    in-out property <string> cantos_bg_type: "negro";
    in-out property <color> cantos_font_color: white;
    in-out property <image> cantos_bg_image;
    in-out property <bool> cantos_has_image: false;
    in-out property <float> cantos_fondo_opacity: 0.0;
    in-out property <float> cantos_font_scale: 1.0;

    in-out property <string> default_bg_type: ""; // Puede ser "imagen" o "video"
    in-out property <int> default_bg_idx: -1;

    in-out property <color> biblias_custom_color: #0ea5e9;
    in-out property <color> cantos_custom_color: #0ea5e9;
    in-out property <bool> mostrar_selector_color: false;
    in-out property <string> color_target: "biblias";
    property <[[color]]> paleta_colores: [
        [ #93c5fd, #86efac, #fdf08a, #fdba74, #fca5a5, #d8b4fe, #d6d3d1, #ffffff ],
        [ #3b82f6, #22c55e, #eab308, #f97316, #ef4444, #a855f7, #78716c, #e5e7eb ],
        [ #1d4ed8, #166534, #a16207, #c2410c, #b91c1c, #7e22ce, #44403c, #9ca3af ],
        [ #1e3a8a, #14532d, #713f12, #7c2d12, #7f1d1d, #581c87, #292524, #000000 ]
    ];

    in-out property <string> biblias_video_path: "";
    in-out property <string> cantos_video_path: "";

    in property <[image]> biblias_image_data: [];
    in property <[image]> cantos_image_data: [];
    in property <[string]> biblias_video_names: [];
    in property <[string]> cantos_video_names: [];
    in-out property <int> biblias_selected_img: -1;
    in-out property <int> cantos_selected_img: -1;
    in-out property <int> biblias_selected_vid: -1;
    in-out property <int> cantos_selected_vid: -1;

    in property <[MediaItem]> multimedia_items: [];
    in-out property <int> selected_media_idx: -1;

    in-out property <bool> mostrar_menu_media: false;
    in-out property <int> menu_media_idx: -1;
    in-out property <length> menu_media_x: 0px;
    in-out property <length> menu_media_y: 0px;
    in-out property <bool> mostrar_submenu_aspecto: false;

    callback agregar_multimedia();
    callback eliminar_multimedia(int);
    callback cambiar_aspecto_multimedia(int, string);
    callback proyectar_multimedia(int);

    in property <[MediaItem]> video_items: [];
    in-out property <int> selected_video_idx: -1;

    in-out property <bool> mostrar_menu_video: false;
    in-out property <int> menu_video_idx: -1;
    in-out property <length> menu_video_x: 0px;
    in-out property <length> menu_video_y: 0px;

    in-out property <bool> mostrar_submenu_reproduccion: false;
    callback cambiar_modo_reproduccion(int, string);

    callback agregar_video();
    callback eliminar_video(int);
    callback proyectar_video(int);

    in-out property <image> preview_video_frame;
    in-out property <bool> is_preview_playing: false;
    callback toggle_preview_video(int);
    callback seleccionar_video_lista(int);

    in-out property <bool> is_video_projecting: false;
    in-out property <bool> is_proyector_playing: true;
    in-out property <bool> is_proyector_muted: false;
    callback toggle_proyector_mute();
    in-out property <float> proyector_progress: 0.0;
    in-out property <string> proyector_time: "00:00 / 00:00";

    callback toggle_proyector_play();
    callback seek_proyector_video(float);

    callback agregar_a_galeria(string);
    callback seleccionar_galeria_item(string, int);
    callback eliminar_galeria_item(string, int);
    callback cargar_fondo_media(string);
    callback quitar_fondo_media(string);

    in-out property <bool> mostrar_formulario: false;
    in-out property <int> form_id: -1;
    in-out property <string> form_titulo: "";
    in-out property <string> form_letra: "";

    in property <[string]> bible-versions: [];
    in-out property <string> current-bible-version: "";
    in property <[BookInfo]> bible-books: [];
    in-out property <string> bible-search-text: "";
    in-out property <string> bible-search-suggestion: "";
    in-out property <bool> show-bible-chapters: false;
    in-out property <BookInfo> selected-bible-book;
    in property <[ChapterRow]> chapter-rows: [];

    in-out property <bool> mostrar_menu_canto: false;
    in-out property <bool> mostrar_confirmar_eliminar: false;
    in-out property <int> menu_canto_id: -1;
    in-out property <string> menu_canto_titulo: "";
    in-out property <length> menu_x: 0px;
    in-out property <length> menu_y: 0px;

    callback buscar_cantos(string);
    callback abrir_proyector();
    callback seleccionar_canto(int);
    callback proyectar_estrofa(string, string);
    callback cargar_datos_edicion(int);
    callback guardar_canto(int, string, string);
    callback eliminar_canto(int);
    callback abrir_formulario_nuevo();
    callback abrir_formulario_editar(int, string);
    callback confirmar_eliminar_canto(int, string);
    callback bible-version-changed(string);
    callback bible-search-changed(string);
    callback bible-search-accepted(string);
    callback bible-book-selected(BookInfo);
    callback bible-chapter-selected(int);

    public function focus_panel() { panel-focus.focus(); }

    // ══════════════════════════════════════════════════════════════
    //  LAYOUT PRINCIPAL  (2 columnas: sidebar izquierdo + central)
    // ══════════════════════════════════════════════════════════════
    Rectangle {
        width: 100%; height: 100%;

        HorizontalLayout {

            // ╔══════════════════════════════════════════════════╗
            // ║   COLUMNA 1: SIDEBAR UNIFICADO (nav + biblioteca) ║
            // ╚══════════════════════════════════════════════════╝
            Rectangle {
                width: 300px; background: #111111;

                VerticalLayout {

                    // ── BARRA DE TABS ───────────────────────────
                    Rectangle {
                        height: 34px; background: #0d0d0d;

                        HorizontalLayout {
                            TabButton {
                                horizontal-stretch: 1; height: 34px;
                                icon: "🎵"; text: "CANTOS";
                                active: root.active-tab == "cantos";
                                clicked => { 
                                    root.active-tab = "cantos"; 
                                    root.elemento_seleccionado = ""; 
                                    root.estrofas_actuales = []; 
                                    root.active_estrofa_index = -1;
                                    root.sync_estilos(); 
                                }
                            }
                            TabButton {
                                horizontal-stretch: 1; height: 34px;
                                icon: "📖"; text: "BIBLIA";
                                active: root.active-tab == "biblias";
                                clicked => { 
                                    root.active-tab = "biblias"; 
                                    root.elemento_seleccionado = ""; 
                                    root.estrofas_actuales = []; 
                                    root.active_estrofa_index = -1;
                                    root.sync_estilos(); 
                                }
                            }
                            TabButton {
                                horizontal-stretch: 1; height: 34px;
                                icon: "🖼️"; text: "IMGS";
                                active: root.active-tab == "imagenes";
                                clicked => { 
                                    root.active-tab = "imagenes"; 
                                    root.elemento_seleccionado = "";
                                    root.sync_estilos(); 
                                }
                            }
                            TabButton {
                                horizontal-stretch: 1; height: 34px;
                                icon: "🎞️"; text: "VIDEOS";
                                active: root.active-tab == "videos";
                                clicked => { 
                                    root.active-tab = "videos"; 
                                    root.elemento_seleccionado = "";
                                    root.sync_estilos(); 
                                }
                            }
                            TabButton {
                                horizontal-stretch: 1; height: 34px;
                                icon: "📄"; text: "PDF";
                                active: root.active-tab == "pdf";
                                clicked => { 
                                    root.active-tab = "pdf"; 
                                    root.elemento_seleccionado = "";
                                    root.sync_estilos(); 
                                }
                            }
                        }

                        Rectangle { y: parent.height - 1px; height: 1px; background: rgba(255, 255, 255, 0.05); }
                    }

                    // ── CONTENIDO DE BIBLIOTECA (vertical-stretch) ──
                    Rectangle {
                        vertical-stretch: 1;

                        // ── TAB CANTOS ──
                        if (root.active-tab == "cantos") : VerticalLayout {
                            // Buscador
                            Rectangle {
                                height: 52px;
                                Rectangle {
                                    height: 32px; x: 10px; y: 10px; width: parent.width - 20px;
                                    border-radius: 4px; background: #1f1f1f; border-width: 1px; border-color: rgba(255,255,255,0.08);
                                    HorizontalLayout {
                                        padding-left: 10px; spacing: 6px;
                                        Text { text: "🔍"; font-size: 10px; color: #4b5563; vertical-alignment: center; }
                                        TextInput { text <=> root.buscador_texto; font-size: 10px; color: #f3f4f6; vertical-alignment: center; horizontal-stretch: 1; edited => { root.buscar_cantos(self.text); } }
                                    }
                                }
                            }
                            // Lista de cantos
                            Rectangle {
                                vertical-stretch: 1; background: rgba(0, 0, 0, 0.3);
                                ScrollView {
                                    VerticalLayout {
                                        padding-left: 4px; padding-right: 4px; padding-top: 4px; spacing: 0px;
                                        for canto in root.cantos : Rectangle {
                                            height: 36px;
                                            background: touch-canto.has-hover ? rgba(14, 165, 233, 0.2) : transparent;
                                            touch-canto := TouchArea {
                                                clicked => { root.seleccionar_canto(canto.id); }
                                                pointer-event(e) => {
                                                    if (e.button == PointerEventButton.right && e.kind == PointerEventKind.up) {
                                                        root.menu_canto_id = canto.id;
                                                        root.menu_canto_titulo = canto.titulo;
                                                        root.menu_x = min(self.absolute-position.x + self.mouse-x, root.width - 185px);
                                                        root.menu_y = min(self.absolute-position.y + self.mouse-y, root.height - 114px);
                                                        root.mostrar_menu_canto = true;
                                                    }
                                                }
                                            }
                                            HorizontalLayout {
                                                padding-left: 10px; padding-right: 10px; spacing: 8px;
                                                Text { text: canto.titulo; color: #e5e7eb; font-size: 11px; font-weight: 700; vertical-alignment: center; horizontal-stretch: 1; }
                                            }
                                            Rectangle { y: parent.height - 1px; height: 1px; background: rgba(255, 255, 255, 0.05); }
                                        }
                                    }
                                }
                            }
                        }

                        // ── TAB BIBLIAS ──
                        if (root.active-tab == "biblias") : VerticalLayout {
                            padding: 10px; spacing: 10px;
                            ComboBox { height: 32px; width: 100%; model: root.bible-versions; current-value <=> root.current-bible-version; selected(val) => { root.bible-version-changed(val); } }
                            Rectangle {
                                height: 32px; width: 100%; background: #1f1f1f; border-radius: 4px; border-width: 1px; border-color: rgba(255, 255, 255, 0.08);
                                HorizontalLayout {
                                    padding-left: 8px; padding-right: 8px; spacing: 6px;
                                    Text { text: "🔍"; font-size: 10px; color: #4b5563; vertical-alignment: center; }
                                    search_focus := FocusScope {
                                        horizontal-stretch: 1; forward-focus: search_input;
                                        key-pressed(event) => {
                                            if (event.text == Key.Tab || event.text == Key.RightArrow) {
                                                if (root.bible-search-suggestion != "" && root.bible-search-suggestion != root.bible-search-text) {
                                                    root.bible-search-text = root.bible-search-suggestion + " ";
                                                    root.bible-search-suggestion = "";
                                                    root.bible-search-changed(root.bible-search-text);
                                                    search_input.set-selection-offsets(999, 999);
                                                    return accept;
                                                }
                                            }
                                            return reject;
                                        }
                                        Rectangle {
                                            width: 100%; height: 100%;
                                            Text { text: root.bible-search-suggestion; color: #4b5563; font-size: 10px; vertical-alignment: center; horizontal-alignment: left; width: 100%; }
                                            search_input := TextInput { width: 100%; height: 100%; text <=> root.bible-search-text; color: #f3f4f6; font-size: 10px; vertical-alignment: center; edited => { root.bible-search-changed(self.text); } accepted => { root.bible-search-accepted(self.text); } }
                                        }
                                    }
                                }
                            }
                            if (!root.show-bible-chapters) : Rectangle {
                                vertical-stretch: 1; background: rgba(0, 0, 0, 0.3); border-radius: 8px;
                                ScrollView {
                                    VerticalLayout {
                                        padding: 4px;
                                        for book in root.bible-books : Rectangle {
                                            height: 36px; background: touch-book.has-hover ? rgba(14, 165, 233, 0.2) : transparent;
                                            touch-book := TouchArea { clicked => { root.selected-bible-book = book; root.show-bible-chapters = true; root.bible-book-selected(book); } }
                                            HorizontalLayout { padding-left: 8px; padding-right: 8px; Text { text: book.nombre; color: touch-book.has-hover ? white : #9ca3af; font-size: 11px; font-weight: 700; vertical-alignment: center; } Rectangle { horizontal-stretch: 1; } }
                                            Rectangle { y: parent.height - 1px; height: 1px; background: rgba(255, 255, 255, 0.05); }
                                        }
                                    }
                                }
                            }
                            if (root.show-bible-chapters) : Rectangle {
                                vertical-stretch: 1; background: rgba(0, 0, 0, 0.3); border-radius: 8px;
                                VerticalLayout {
                                    Rectangle {
                                        height: 36px;
                                        touch-back := TouchArea { clicked => { root.show-bible-chapters = false; } }
                                        HorizontalLayout { padding-left: 12px; spacing: 8px; Text { text: "<"; color: #0ea5e9; font-weight: 900; vertical-alignment: center;} Text { text: root.selected-bible-book.nombre; color: #0ea5e9; font-size: 11px; font-weight: 900; vertical-alignment: center; } }
                                        Rectangle { y: parent.height - 1px; height: 1px; background: rgba(255, 255, 255, 0.05); }
                                    }
                                    ScrollView {
                                        VerticalLayout {
                                            padding: 12px; spacing: 8px; alignment: start;
                                            for row in root.chapter-rows : HorizontalLayout {
                                                spacing: 8px; height: 42px;
                                                for cap in row.caps : Rectangle {
                                                    width: 42px; border-radius: 6px; border-width: 1px; border-color: rgba(255,255,255,0.05);
                                                    background: touch-cap.has-hover ? #0ea5e9 : #1f1f1f;
                                                    touch-cap := TouchArea { clicked => { root.bible-chapter-selected(cap); } }
                                                    Text { text: cap; color: touch-cap.has-hover ? white : #d1d5db; font-size: 12px; font-weight: 700; horizontal-alignment: center; vertical-alignment: center; }
                                                }
                                                Rectangle { horizontal-stretch: 1; }
                                            }
                                        }
                                    }
                                }
                            }
                        }

                        // ── TAB IMÁGENES MULTIMEDIA ──
                        if (root.active-tab == "imagenes") : Rectangle {
                            vertical-stretch: 1; background: rgba(0, 0, 0, 0.3);
                            TouchArea {
                                pointer-event(e) => {
                                    if (e.button == PointerEventButton.right && e.kind == PointerEventKind.up) {
                                        root.menu_media_idx = -1;
                                        root.menu_media_x = min(self.absolute-position.x + self.mouse-x, root.width - 180px);
                                        root.menu_media_y = min(self.absolute-position.y + self.mouse-y, root.height - 150px);
                                        root.mostrar_menu_media = true;
                                    }
                                }
                                ScrollView {
                                    VerticalLayout {
                                        padding: 8px; spacing: 8px;
                                        for item[idx] in root.multimedia_items : Rectangle {
                                            height: 52px; border-radius: 6px;
                                            background: root.selected_media_idx == idx ? rgba(14, 165, 233, 0.2) : (touch-media.has-hover ? rgba(255, 255, 255, 0.05) : transparent);
                                            touch-media := TouchArea {
                                                clicked => { root.selected_media_idx = idx; }
                                                double-clicked => { root.proyectar_multimedia(idx); }
                                                pointer-event(e) => {
                                                    if (e.button == PointerEventButton.right && e.kind == PointerEventKind.up) {
                                                        root.menu_media_idx = idx;
                                                        root.menu_media_x = self.absolute-position.x + self.mouse-x;
                                                        root.menu_media_y = self.absolute-position.y + self.mouse-y;
                                                        root.mostrar_menu_media = true;
                                                    }
                                                }
                                            }
                                            HorizontalLayout {
                                                padding: 6px; spacing: 12px;
                                                Rectangle {
                                                    width: 72px; height: 40px; border-radius: 4px; clip: true; background: #000;
                                                    Image {
                                                        source: item.img; width: 100%; height: 100%;
                                                        image-fit: item.aspecto == "rellenar" ? cover : (item.aspecto == "estirar" ? fill : contain);
                                                    }
                                                }
                                                VerticalLayout {
                                                    alignment: center; spacing: 4px;
                                                    Text { text: item.nombre; color: #f3f4f6; font-size: 11px; font-weight: 700; horizontal-stretch: 1; overflow: elide; }
                                                    if (root.default_bg_type == "imagen" && root.default_bg_idx == idx) : Text { text: "FONDO PREDETERMINADO"; color: #eab308; font-size: 9px; font-weight: 800; }
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }

                        // ── TAB VIDEOS (BIBLIOTECA) ──
                        if (root.active-tab == "videos") : Rectangle {
                            vertical-stretch: 1; background: rgba(0, 0, 0, 0.3);
                            TouchArea {
                                pointer-event(e) => {
                                    if (e.button == PointerEventButton.right && e.kind == PointerEventKind.up) {
                                        root.menu_video_idx = -1;
                                        root.menu_video_x = min(self.absolute-position.x + self.mouse-x, root.width - 180px);
                                        root.menu_video_y = min(self.absolute-position.y + self.mouse-y, root.height - 146px);
                                        root.mostrar_menu_video = true;
                                    }
                                }
                                ScrollView {
                                    VerticalLayout {
                                        padding: 8px; spacing: 8px;
                                        for item[idx] in root.video_items : Rectangle {
                                            height: 60px; border-radius: 6px;
                                            background: root.selected_video_idx == idx ? rgba(14, 165, 233, 0.2) : (touch-vid.has-hover ? rgba(255, 255, 255, 0.05) : transparent);
                                            touch-vid := TouchArea {
                                                clicked => { root.seleccionar_video_lista(idx); }
                                                double-clicked => { root.proyectar_video(idx); }
                                                pointer-event(e) => {
                                                    if (e.button == PointerEventButton.right && e.kind == PointerEventKind.up) {
                                                        root.menu_video_idx = idx;
                                                        root.menu_video_x = self.absolute-position.x + self.mouse-x;
                                                        root.menu_video_y = self.absolute-position.y + self.mouse-y;
                                                        root.mostrar_menu_video = true;
                                                    }
                                                }
                                            }
                                            HorizontalLayout {
                                                padding: 6px; spacing: 12px;
                                                Rectangle {
                                                    width: 80px; height: 45px; border-radius: 4px; clip: true; background: #000;
                                                    Image { source: item.img; width: 100%; height: 100%; image-fit: cover; }
                                                    Text { text: "▶"; color: rgba(255,255,255,0.7); font-size: 14px; horizontal-alignment: center; vertical-alignment: center; }
                                                }
                                                VerticalLayout {
                                                    alignment: center; spacing: 4px;
                                                    Text { text: item.nombre; color: #f3f4f6; font-size: 11px; font-weight: 700; horizontal-stretch: 1; overflow: elide; }
                                                    if (item.is_loop) : Text { text: "BUCLE ACTIVADO"; color: #0ea5e9; font-size: 9px; font-weight: 800; }
                                                    if (root.default_bg_type == "video" && root.default_bg_idx == idx) : Text { text: "FONDO PREDETERMINADO"; color: #eab308; font-size: 9px; font-weight: 800; }
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }

                        // ── TAB PDF (placeholder) ──
                        if (root.active-tab == "pdf") : VerticalLayout {
                            alignment: center; spacing: 16px;
                            Text { text: "📄"; color: #374151; font-size: 48px; horizontal-alignment: center; }
                            Text { text: "PRESENTACIONES PDF"; color: #374151; font-size: 13px; font-weight: 700; horizontal-alignment: center; }
                        }
                    }

                    // ── SECCIÓN FAVORITOS ───────────────────────
                    Rectangle {
                        height: 250px; background: #0d0d0d;

                        VerticalLayout {
                            // Encabezado favoritos
                            Rectangle {
                                height: 28px;
                                HorizontalLayout {
                                    padding-left: 12px; padding-right: 12px;
                                    Text { text: "★  FAVORITOS"; color: #374151; font-size: 9px; font-weight: 700; letter-spacing: 0.4px; vertical-alignment: center; horizontal-stretch: 1; }
                                }
                                Rectangle { y: parent.height - 1px; height: 1px; background: rgba(255,255,255,0.04); }
                            }

                            // Área de favoritos
                            Rectangle {
                                vertical-stretch: 1;
                                Text {
                                    text: "Mantén pulsado un elemento\npara añadirlo a favoritos";
                                    color: #2d2d2d; font-size: 9px; font-weight: 600;
                                    horizontal-alignment: center; vertical-alignment: center;
                                    wrap: word-wrap; width: 100%; height: 100%;
                                }
                            }
                        }
                    }
                }
            }

            // ╔══════════════════════════════════════════════╗
            // ║  COLUMNA 2: PANEL CENTRAL                    ║
            // ╚══════════════════════════════════════════════╝
            Rectangle {
                horizontal-stretch: 1; background: #18181b;
                VerticalLayout {
                    // ── BARRA SUPERIOR CON TÍTULO + BOTONES ────
                    Rectangle {
                        height: 48px; background: #18181b;
                        HorizontalLayout {
                            padding-left: 24px; padding-right: 16px; spacing: 10px;
                            // Título del elemento seleccionado
                            Text {
                                text: root.elemento_seleccionado == "" ? "SELECCIONA UN ELEMENTO" : "📖 " + root.elemento_seleccionado;
                                color: root.elemento_seleccionado == "" ? #6b7280 : #0ea5e9;
                                font-size: 12px; font-weight: 900; vertical-alignment: center; horizontal-stretch: 1;
                            }
                            // ── Botón PERSONALIZAR ──
                            Rectangle {
                                width: 28px; height: 28px; border-radius: 8px;
                                background: touch-pers-top.has-hover ? rgba(255,255,255,0.08) : rgba(255,255,255,0.04);
                                border-width: 1px; border-color: rgba(255,255,255,0.06);
                                touch-pers-top := TouchArea { clicked => { root.mostrar_personalizar = true; } }
                                Text { text: "⚙"; font-size: 12px; color: touch-pers-top.has-hover ? white : #4b5563; horizontal-alignment: center; vertical-alignment: center; }
                            }
                            
                            // ── Botón LIVE ──
                            Rectangle {
                                width: 52px; height: 28px; border-radius: 8px;
                                background: touch-live.has-hover ? #b91c1c : #dc2626;
                                drop-shadow-color: rgba(220, 38, 38, 0.35); drop-shadow-blur: 8px; drop-shadow-offset-y: 2px;
                                touch-live := TouchArea { 
                                    clicked => { 
                                        root.abrir_proyector(); 
                                        if (root.default_bg_type == "imagen" && root.default_bg_idx >= 0 && root.default_bg_idx < root.multimedia_items.length) {
                                            root.proyectar_multimedia(root.default_bg_idx);
                                        } else if (root.default_bg_type == "video" && root.default_bg_idx >= 0 && root.default_bg_idx < root.video_items.length) {
                                            root.proyectar_video(root.default_bg_idx);
                                        }
                                    } 
                                }
                                Text { text: "LIVE"; font-size: 9px; font-weight: 900; letter-spacing: 0.8px; color: white; horizontal-alignment: center; vertical-alignment: center; }
                            }
                        }
                        Rectangle { y: parent.height - 1px; height: 1px; background: rgba(255, 255, 255, 0.06); }
                    }

                    panel-focus := FocusScope {
                        vertical-stretch: 1;
                        key-pressed(event) => {
                            if (root.estrofas_actuales.length > 0 && (root.active-tab == "cantos" || root.active-tab == "biblias")) {
                                if (event.text == Key.UpArrow) {
                                    if (root.active_estrofa_index > 0) {
                                        root.active_estrofa_index -= 1;
                                        root.proyectar_estrofa(root.estrofas_actuales[root.active_estrofa_index].texto, root.active-tab == "biblias" ? root.elemento_seleccionado + ":" + root.estrofas_actuales[root.active_estrofa_index].orden : "");
                                        
                                        // Scroll dinámico con valor NEGATIVO para enlace bidireccional
                                        root.scroll_to_y = root.active-tab == "biblias" 
                                            ? -(root.active_estrofa_index * 115px > 150px ? root.active_estrofa_index * 115px - 150px : 0px)
                                            : -((root.active_estrofa_index / 3) * 192px > 150px ? (root.active_estrofa_index / 3) * 192px - 150px : 0px);
                                    }
                                    return accept;
                                }
                                if (event.text == Key.DownArrow) {
                                    if (root.active_estrofa_index < root.estrofas_actuales.length - 1) {
                                        root.active_estrofa_index += 1;
                                        root.proyectar_estrofa(root.estrofas_actuales[root.active_estrofa_index].texto, root.active-tab == "biblias" ? root.elemento_seleccionado + ":" + root.estrofas_actuales[root.active_estrofa_index].orden : "");
                                        
                                        // Scroll dinámico con valor NEGATIVO para enlace bidireccional
                                        root.scroll_to_y = root.active-tab == "biblias" 
                                            ? -(root.active_estrofa_index * 115px > 150px ? root.active_estrofa_index * 115px - 150px : 0px)
                                            : -((root.active_estrofa_index / 3) * 192px > 150px ? (root.active_estrofa_index / 3) * 192px - 150px : 0px);
                                    } else if (root.active_estrofa_index == -1) {
                                        root.active_estrofa_index = 0;
                                        root.proyectar_estrofa(root.estrofas_actuales[root.active_estrofa_index].texto, root.active-tab == "biblias" ? root.elemento_seleccionado + ":" + root.estrofas_actuales[root.active_estrofa_index].orden : "");
                                        root.scroll_to_y = 0px;
                                    }
                                    return accept;
                                }
                            }
                            return reject;
                        }

                        Rectangle {
                            width: 100%; height: 100%; background: #18181b;

                            // ── VISTA CANTOS / BIBLIAS ──
                            if (root.active-tab == "cantos" || root.active-tab == "biblias") : Rectangle {
                                width: 100%; height: 100%;
                                if (root.estrofas_actuales.length == 0) : VerticalLayout {
                                    alignment: center; spacing: 16px;
                                    Text { text: "𝅘𝅥𝅮𝅘𝅥𝅮"; color: #374151; font-size: 48px; horizontal-alignment: center; }
                                    Text { text: root.elemento_seleccionado == "" ? "SELECCIONA UN ARCHIVO DE LA BIBLIOTECA" : root.elemento_seleccionado; color: #374151; font-size: 13px; font-weight: 700; horizontal-alignment: center; }
                                }
                                if (root.estrofas_actuales.length > 0) : ScrollView {
                                    viewport-y <=> root.scroll_to_y;
                                    VerticalLayout {
                                        padding: 16px; spacing: 12px;
                                        // ── CUADRÍCULA 3×N ──
                                        // Fila 0: índices 0,1,2
                                        // Fila 1: índices 3,4,5 … etc.
                                        // Se generan filas de hasta 3 celdas usando GridLayout
                                        GridLayout {
                                            spacing: 12px;
                                            for estrofa[idx] in root.estrofas_actuales : Rectangle {
                                                row: root.active-tab == "biblias" ? idx : idx / 3;
                                                col: root.active-tab == "biblias" ? 0 : mod(idx, 3);
                                                height: root.active-tab == "biblias" ? 103px : 180px;
                                                border-radius: 8px; border-width: 1px;
                                                background: idx == root.active_estrofa_index
                                                    ? rgba(220, 38, 38, 0.18)
                                                    : (touch-estrofa.has-hover ? rgba(14, 165, 233, 0.10) : rgba(255, 255, 255, 0.02));
                                                border-color: idx == root.active_estrofa_index
                                                    ? #dc2626
                                                    : (touch-estrofa.has-hover ? #0ea5e9 : rgba(255,255,255,0.06));

                                                touch-estrofa := TouchArea {
                                                    clicked => {
                                                        root.active_estrofa_index = idx;
                                                        root.proyectar_estrofa(
                                                            estrofa.texto,
                                                            root.active-tab == "biblias"
                                                                ? root.elemento_seleccionado + ":" + estrofa.orden
                                                                : ""
                                                        );
                                                        panel-focus.focus();
                                                    }
                                                }

                                                VerticalLayout {
                                                    padding: 10px; spacing: 6px;

                                                    // ── Cabecera: número + badge LIVE/PROYECTAR ──
                                                    HorizontalLayout {
                                                        spacing: 6px; alignment: space-between;
                                                        Text {
                                                            text: estrofa.orden;
                                                            color: idx == root.active_estrofa_index ? #dc2626 : #0ea5e9;
                                                            font-weight: 900; font-size: 10px;
                                                            vertical-alignment: center;
                                                        }
                                                        Rectangle {
                                                            width: 54px; height: 18px; border-radius: 4px; border-width: 1px;
                                                            background: idx == root.active_estrofa_index ? #dc2626 : transparent;
                                                            border-color: idx == root.active_estrofa_index
                                                                ? #dc2626
                                                                : (touch-estrofa.has-hover ? rgba(14,165,233,0.5) : rgba(255,255,255,0.08));
                                                            Text {
                                                                text: idx == root.active_estrofa_index ? "EN VIVO" : "CLIC";
                                                                color: idx == root.active_estrofa_index ? white : (touch-estrofa.has-hover ? #0ea5e9 : #4b5563);
                                                                font-size: 8px; font-weight: 800;
                                                                horizontal-alignment: center; vertical-alignment: center;
                                                            }
                                                        }
                                                    }

                                                    // ── Separador ──
                                                    Rectangle {
                                                        height: 1px;
                                                        background: idx == root.active_estrofa_index
                                                            ? rgba(220,38,38,0.3)
                                                            : rgba(255,255,255,0.05);
                                                    }

                                                    // ── Texto de la estrofa (auto-ajustado) ──
                                                    Rectangle {
                                                        vertical-stretch: 1; clip: true;
                                                        Text {
                                                            text: estrofa.texto;
                                                            color: idx == root.active_estrofa_index
                                                                ? white
                                                                : (touch-estrofa.has-hover ? white : #d1d5db);
                                                            // Tamaño calculado desde Rust por estrofa
                                                            font-size: max(9px, estrofa.font_size * 1px);
                                                            wrap: word-wrap;
                                                            width: 100%; height: 100%;
                                                            vertical-alignment: top;
                                                        }
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }
                            }

                            // ── VISTA IMÁGENES (panel central) ──
                            if (root.active-tab == "imagenes") : Rectangle {
                                width: 100%; height: 100%; background: #18181b;
                                touch-central-media := TouchArea {
                                    clicked => { root.proyectar_multimedia(root.selected_media_idx); }
                                }
                                if (root.selected_media_idx >= 0 && root.selected_media_idx < root.multimedia_items.length) : VerticalLayout {
                                    Rectangle {
                                        vertical-stretch: 1; horizontal-stretch: 1; clip: true;
                                        Image {
                                            source: root.multimedia_items[root.selected_media_idx].img;
                                            width: 100%; height: 100%;
                                            image-fit: root.multimedia_items[root.selected_media_idx].aspecto == "rellenar" ? cover : (root.multimedia_items[root.selected_media_idx].aspecto == "estirar" ? fill : contain);
                                        }
                                        Rectangle {
                                            width: 175px; height: 32px; x: 10px; y: 10px;
                                            background: #111111; border-radius: 6px; border-width: 1px; border-color: rgba(255,255,255,0.05);
                                            Text {
                                                text: root.multimedia_items[root.selected_media_idx].aspecto == "centro" ? "MODO: AJUSTAR AL CENTRO" : root.multimedia_items[root.selected_media_idx].aspecto == "rellenar" ? "MODO: RELLENAR PANTALLA" : "MODO: ESTIRAR";
                                                color: #e5e7eb; font-size: 10px; font-weight: 800; horizontal-alignment: center; vertical-alignment: center;
                                            }
                                        }
                                    }
                                }
                                if (root.selected_media_idx == -1 || root.multimedia_items.length == 0) : VerticalLayout {
                                    alignment: center; spacing: 16px;
                                    Text { text: "🖼️"; color: #374151; font-size: 48px; horizontal-alignment: center; }
                                    Text { text: "SELECCIONA UNA IMAGEN DE LA BIBLIOTECA"; color: #374151; font-size: 13px; font-weight: 700; horizontal-alignment: center; }
                                }
                            }

                            // ── VISTA VIDEOS (panel central) ──
                            if (root.active-tab == "videos") : Rectangle {
                                width: 100%; height: 100%; background: #18181b;
                                if (root.selected_video_idx >= 0 && root.selected_video_idx < root.video_items.length) : VerticalLayout {
                                    padding: 16px; spacing: 12px;
                                    Rectangle {
                                        height: 45px; border-radius: 6px;
                                        background: root.is_video_projecting ? #ef4444 : #0ea5e9;
                                        TouchArea {
                                            clicked => {
                                                if (!root.is_video_projecting) { root.proyectar_video(root.selected_video_idx); }
                                            }
                                        }
                                        Text {
                                            text: root.is_video_projecting ? "🔴 VIDEO EN PROYECCIÓN" : "▶ PROYECTAR VIDEO";
                                            color: white; font-weight: 700; font-size: 14px;
                                            horizontal-alignment: center; vertical-alignment: center;
                                        }
                                    }
                                    Rectangle {
                                        vertical-stretch: 1; horizontal-stretch: 1; clip: true; background: black; border-radius: 8px;
                                        Image { source: root.preview_video_frame; width: 100%; height: 100%; image-fit: contain; }
                                        TouchArea {
                                            clicked => { root.toggle_preview_video(root.selected_video_idx); }
                                            if (!root.is_preview_playing) : Rectangle {
                                                width: 60px; height: 60px; border-radius: 30px;
                                                background: rgba(0,0,0,0.6); border-width: 2px; border-color: rgba(255,255,255,0.2);
                                                x: (parent.width - 60px) / 2; y: (parent.height - 60px) / 2;
                                                Text { text: "▶"; color: white; font-size: 24px; horizontal-alignment: center; vertical-alignment: center; }
                                            }
                                        }
                                    }
                                    if (root.is_video_projecting) : HorizontalLayout {
                                        height: 40px; spacing: 16px; padding-left: 16px; padding-right: 16px;
                                        Rectangle {
                                            width: 40px; height: 40px; border-radius: 20px; background: #27272a;
                                            TouchArea { clicked => { root.toggle_proyector_play(); } }
                                            Text { text: root.is_proyector_playing ? "⏸" : "▶"; color: white; font-size: 18px; horizontal-alignment: center; vertical-alignment: center; }
                                        }
                                        Rectangle {
                                            width: 40px; height: 40px; border-radius: 20px; background: #27272a;
                                            TouchArea { clicked => { root.toggle_proyector_mute(); } }
                                            Text { text: root.is_proyector_muted ? "🔇" : "🔊"; color: white; font-size: 18px; horizontal-alignment: center; vertical-alignment: center; }
                                        }
                                        VerticalLayout {
                                            alignment: center; horizontal-stretch: 1;
                                            Rectangle {
                                                horizontal-stretch: 1; height: 12px; background: #3f3f46; border-radius: 6px;
                                                Rectangle { x: 0; y: 0; width: parent.width * root.proyector_progress; height: 100%; background: #0ea5e9; border-radius: 6px; }
                                                touch_progress := TouchArea {
                                                    width: 100%; height: 100%;
                                                    clicked => { root.seek_proyector_video(touch_progress.mouse-x / touch_progress.width); }
                                                }
                                            }
                                        }
                                        Text { text: root.proyector_time; color: #a1a1aa; font-size: 13px; font-weight: 600; vertical-alignment: center; }
                                    }
                                }
                                if (root.selected_video_idx == -1 || root.video_items.length == 0) : VerticalLayout {
                                    alignment: center; spacing: 16px;
                                    Text { text: "🎞️"; color: #374151; font-size: 48px; horizontal-alignment: center; }
                                    Text { text: "SELECCIONA UN VIDEO DE LA BIBLIOTECA"; color: #374151; font-size: 13px; font-weight: 700; horizontal-alignment: center; }
                                }
                            }

                            // ── VISTA PDF (placeholder) ──
                            if (root.active-tab == "pdf") : VerticalLayout {
                                alignment: center; spacing: 16px;
                                Text { text: "📄"; color: #374151; font-size: 48px; horizontal-alignment: center; }
                                Text { text: "PRESENTACIÓN PDF"; color: #374151; font-size: 13px; font-weight: 700; horizontal-alignment: center; }
                            }
                        }
                    }
                }
            }
        }
    }

    // ══════════════════════════════════════════════════════════════
    //  MENÚ CONTEXTUAL MULTIMEDIA IMÁGENES (sin cambios)
    // ══════════════════════════════════════════════════════════════
    if (root.mostrar_menu_media) : Rectangle {
        width: 100%; height: 100%; background: transparent;
        TouchArea {
            clicked => { root.mostrar_menu_media = false; root.mostrar_submenu_aspecto = false; }
        }
        Rectangle {
            x: root.menu_media_x; y: root.menu_media_y;
            width: 180px; height: root.menu_media_idx != -1 ? 150px : 40px;
            background: #1e1e1e; border-radius: 8px; border-width: 1px; border-color: #374151;
            drop-shadow-color: rgba(0,0,0,0.6); drop-shadow-blur: 16px;
            TouchArea {}
            VerticalLayout {
                padding: 4px; spacing: 2px;
                MenuItem { text: "Agregar Imagen"; icon: "+"; clicked => { root.mostrar_menu_media = false; root.mostrar_submenu_aspecto = false; root.agregar_multimedia(); } }
                if (root.menu_media_idx != -1) : HorizontalLayout { padding-left: 6px; padding-right: 6px; padding-top: 2px; padding-bottom: 2px; Rectangle { height: 1px; background: #2d2d2d; } }
                if (root.menu_media_idx != -1) : VerticalLayout {
                    spacing: 2px;
                    MenuItem { text: "Aspecto de Imagen"; icon: "⛶"; has_submenu: true; clicked => { root.mostrar_submenu_aspecto = !root.mostrar_submenu_aspecto; } }
                    
                    // NUEVO BOTON PREDETERMINADO
                    MenuItem { text: "Fondo Predeterminado"; icon: "★"; text_color: #eab308; icon_color: #eab308; clicked => { root.default_bg_type = "imagen"; root.default_bg_idx = root.menu_media_idx; root.mostrar_menu_media = false; } }
                    
                    HorizontalLayout { padding-left: 6px; padding-right: 6px; padding-top: 2px; padding-bottom: 2px; Rectangle { height: 1px; background: #2d2d2d; } }
                    MenuItem { text: "Eliminar Imagen"; icon: "🗑"; text_color: #f87171; icon_color: #f87171; clicked => { root.mostrar_menu_media = false; root.mostrar_submenu_aspecto = false; root.eliminar_multimedia(root.menu_media_idx); } }
                }
            }
        }
        if (root.mostrar_submenu_aspecto && root.menu_media_idx != -1) : Rectangle {
            x: root.menu_media_x - 172px; y: root.menu_media_y + 36px;
            width: 170px; height: 106px;
            background: #1e1e1e; border-radius: 8px; border-width: 1px; border-color: #374151;
            drop-shadow-color: rgba(0,0,0,0.6); drop-shadow-blur: 16px;
            TouchArea {}
            VerticalLayout {
                padding: 4px; spacing: 2px;
                MenuItem { text: "Ajustar al centro"; icon: "⛶"; clicked => { root.mostrar_menu_media = false; root.mostrar_submenu_aspecto = false; root.cambiar_aspecto_multimedia(root.menu_media_idx, "centro"); } }
                MenuItem { text: "Rellenar pantalla"; icon: "⛶"; clicked => { root.mostrar_menu_media = false; root.mostrar_submenu_aspecto = false; root.cambiar_aspecto_multimedia(root.menu_media_idx, "rellenar"); } }
                MenuItem { text: "Estirar"; icon: "T"; text_color: #0ea5e9; icon_color: #0ea5e9; clicked => { root.mostrar_menu_media = false; root.mostrar_submenu_aspecto = false; root.cambiar_aspecto_multimedia(root.menu_media_idx, "estirar"); } }
            }
        }
    }

    // ══════════════════════════════════════════════════════════════
    //  MENÚ CONTEXTUAL VIDEOS (sin cambios)
    // ══════════════════════════════════════════════════════════════
    if (root.mostrar_menu_video) : Rectangle {
        width: 100%; height: 100%; background: transparent;
        TouchArea { clicked => { root.mostrar_menu_video = false; root.mostrar_submenu_reproduccion = false; } }
        if (root.mostrar_submenu_reproduccion && root.menu_video_idx != -1) : Rectangle {
            x: root.menu_video_x - 165px; y: root.menu_video_y + 35px;
            width: 160px; height: 72px;
            background: #1e1e1e; border-radius: 8px; border-width: 1px; border-color: #374151;
            drop-shadow-color: rgba(0,0,0,0.6); drop-shadow-blur: 16px;
            VerticalLayout {
                padding: 4px; spacing: 2px;
                Rectangle {
                    height: 30px; border-radius: 4px; background: touch_norm.has-hover ? #374151 : transparent;
                    touch_norm := TouchArea { clicked => { root.cambiar_modo_reproduccion(root.menu_video_idx, "normal"); root.mostrar_submenu_reproduccion = false; root.mostrar_menu_video = false; } }
                    Text { text: "Normal (Una vez)"; color: white; font-size: 13px; x: 12px; vertical-alignment: center; height: 100%; }
                }
                Rectangle {
                    height: 30px; border-radius: 4px; background: touch_loop.has-hover ? #374151 : transparent;
                    touch_loop := TouchArea { clicked => { root.cambiar_modo_reproduccion(root.menu_video_idx, "bucle"); root.mostrar_submenu_reproduccion = false; root.mostrar_menu_video = false; } }
                    Text { text: "Bucle Infinito"; color: #0ea5e9; font-size: 13px; font-weight: 700; x: 12px; vertical-alignment: center; height: 100%; }
                }
            }
        }
        Rectangle {
            x: root.menu_video_x; y: root.menu_video_y;
            width: 180px; height: root.menu_video_idx != -1 ? 146px : 40px;
            background: #1e1e1e; border-radius: 8px; border-width: 1px; border-color: #374151;
            drop-shadow-color: rgba(0,0,0,0.6); drop-shadow-blur: 16px;
            TouchArea {}
            VerticalLayout {
                padding: 4px; spacing: 2px;
                MenuItem { text: "Agregar Video"; icon: "+"; clicked => { root.mostrar_menu_video = false; root.mostrar_submenu_reproduccion = false; root.agregar_video(); } }
                if (root.menu_video_idx != -1) : HorizontalLayout { padding-left: 6px; padding-right: 6px; padding-top: 2px; padding-bottom: 2px; Rectangle { height: 1px; background: #2d2d2d; } }
                if (root.menu_video_idx != -1) : Rectangle {
                    height: 30px; border-radius: 4px; background: touch_rep.has-hover ? #374151 : transparent;
                    touch_rep := TouchArea { clicked => { root.mostrar_submenu_reproduccion = !root.mostrar_submenu_reproduccion; } }
                    HorizontalLayout {
                        padding-left: 8px; padding-right: 8px; alignment: space-between;
                        Text { text: "🔁 Reproducción"; color: white; font-size: 13px; vertical-alignment: center; }
                        Text { text: "›"; color: #0ea5e9; font-size: 16px; vertical-alignment: center; font-weight: 700; }
                    }
                }
                
                // NUEVO BOTON PREDETERMINADO
                if (root.menu_video_idx != -1) : MenuItem { text: "Fondo Predeterminado"; icon: "★"; text_color: #eab308; icon_color: #eab308; clicked => { root.default_bg_type = "video"; root.default_bg_idx = root.menu_video_idx; root.mostrar_menu_video = false; } }
                
                if (root.menu_video_idx != -1) : HorizontalLayout { padding-left: 6px; padding-right: 6px; padding-top: 2px; padding-bottom: 2px; Rectangle { height: 1px; background: #2d2d2d; } }
                if (root.menu_video_idx != -1) : MenuItem { text: "Eliminar Video"; icon: "🗑"; text_color: #f87171; icon_color: #f87171; clicked => { root.mostrar_menu_video = false; root.mostrar_submenu_reproduccion = false; root.eliminar_video(root.menu_video_idx); } }
            }
        }
    }

    // ══════════════════════════════════════════════════════════════
    //  MODAL DE PERSONALIZACIÓN (sin cambios)
    // ══════════════════════════════════════════════════════════════
    // ══════════════════════════════════════════════════════════════
    //  MODAL PERSONALIZACIÓN — diseño minimalista v2
    // ══════════════════════════════════════════════════════════════
    if (root.mostrar_personalizar) : Rectangle {
        width: 100%; height: 100%; background: rgba(0,0,0,0.65);
        nm-backdrop := TouchArea { clicked => { root.mostrar_personalizar = false; } }

        Rectangle {
            width: 620px; height: 498px;
            background: #0d0d0d;
            border-radius: 14px;
            border-width: 1px; border-color: rgba(255,255,255,0.07);
            drop-shadow-color: rgba(0,0,0,0.8); drop-shadow-blur: 40px;
            nm-blocker := TouchArea {}

            property <string> current_gal_tab: "imagenes";

            VerticalLayout {
                // ── HEADER ─────────────────────────────────────────────────
                Rectangle {
                    height: 50px;
                    HorizontalLayout {
                        padding-left: 22px; padding-right: 14px; spacing: 0px;
                        Text { text: "PROYECCIÓN"; color: #2d2d2d; font-size: 9px; font-weight: 900; letter-spacing: 2px; vertical-alignment: center; }
                        Rectangle { horizontal-stretch: 1; }
                        // Pill tab switcher
                        Rectangle {
                            width: 160px; height: 30px; border-radius: 8px;
                            background: rgba(255,255,255,0.04); border-width: 1px; border-color: rgba(255,255,255,0.06);
                            HorizontalLayout { padding: 3px; spacing: 3px;
                                Rectangle { horizontal-stretch: 1; border-radius: 6px; background: root.modal_tab == "biblias" ? rgba(14,165,233,0.25) : transparent; nm-t1 := TouchArea { clicked => { root.modal_tab = "biblias"; } } Text { text: "BIBLIA"; color: root.modal_tab == "biblias" ? #38bdf8 : #3a3a3a; font-size: 9px; font-weight: 900; horizontal-alignment: center; vertical-alignment: center; width: 100%; height: 100%; } }
                                Rectangle { horizontal-stretch: 1; border-radius: 6px; background: root.modal_tab == "cantos" ? rgba(14,165,233,0.25) : transparent; nm-t2 := TouchArea { clicked => { root.modal_tab = "cantos"; } } Text { text: "CANTO"; color: root.modal_tab == "cantos" ? #38bdf8 : #3a3a3a; font-size: 9px; font-weight: 900; horizontal-alignment: center; vertical-alignment: center; width: 100%; height: 100%; } }
                            }
                        }
                        Rectangle { width: 10px; }
                        // Close
                        Rectangle { width: 30px; height: 30px; border-radius: 8px; background: nm-close.has-hover ? rgba(255,255,255,0.06) : transparent; nm-close := TouchArea { clicked => { root.mostrar_personalizar = false; } } Text { text: "✕"; color: #3a3a3a; font-size: 13px; horizontal-alignment: center; vertical-alignment: center; } }
                    }
                }
                Rectangle { height: 1px; background: rgba(255,255,255,0.05); }

                // ── CONTENT ────────────────────────────────────────────────
                Rectangle {
                    vertical-stretch: 1;

                    // ═══ BIBLIA TAB ═════════════════════════════════════════
                    if (root.modal_tab == "biblias") : VerticalLayout {
                        padding-left: 22px; padding-right: 22px; padding-top: 18px; padding-bottom: 16px; spacing: 0px;

                        // — FONDO —
                        Text { text: "FONDO"; color: #272727; font-size: 8px; font-weight: 900; letter-spacing: 2px; }
                        Rectangle { height: 10px; }
                        HorizontalLayout { spacing: 0px; alignment: space-between;
                            // BG type pills
                            HorizontalLayout { spacing: 6px; alignment: start;
                                Rectangle { width: 44px; height: 32px; border-radius: 7px; background: #000000; border-width: 2px; border-color: root.biblias_bg_type == "negro" ? #0ea5e9 : rgba(255,255,255,0.15); nm-bbn := TouchArea { clicked => { root.biblias_bg_type = "negro"; root.sync_estilos(); } } }
                               Rectangle { width: 44px; height: 32px; border-radius: 7px; background: #ffffff; border-width: 2px; border-color: root.biblias_bg_type == "blanco" ? #0ea5e9 : rgba(0,0,0,0.15); nm-bbb := TouchArea { clicked => { root.biblias_bg_type = "blanco"; root.sync_estilos(); } } }
                                Rectangle { width: 66px; height: 32px; border-radius: 7px; background: root.biblias_bg_type == "imagen" ? rgba(14,165,233,0.14) : rgba(255,255,255,0.03); border-width: 1px; border-color: root.biblias_bg_type == "imagen" ? #0ea5e9 : rgba(255,255,255,0.06); nm-bbi := TouchArea { clicked => { root.biblias_bg_type = "imagen"; root.sync_estilos(); } } Text { text: "Imagen"; font-size: 9px; font-weight: 700; color: root.biblias_bg_type == "imagen" ? #38bdf8 : #3d3d3d; horizontal-alignment: center; vertical-alignment: center; }  }
                                Rectangle { width: 62px; height: 32px; border-radius: 7px; background: root.biblias_bg_type == "video" ? rgba(14,165,233,0.14) : rgba(255,255,255,0.03); border-width: 1px; border-color: root.biblias_bg_type == "video" ? #0ea5e9 : rgba(255,255,255,0.06); nm-bbv := TouchArea { clicked => { root.biblias_bg_type = "video"; root.sync_estilos(); } } Text { text: "Video"; font-size: 9px; font-weight: 700; color: root.biblias_bg_type == "video" ? #38bdf8 : #3d3d3d; horizontal-alignment: center; vertical-alignment: center; } }
                            }
                            // Opacity inline
                            HorizontalLayout { spacing: 8px; alignment: end;
                                Text { text: "Opacidad"; color: #2d2d2d; font-size: 9px; font-weight: 700; vertical-alignment: center; }
                                Slider { width: 100px; minimum: 0.0; maximum: 1.0; value <=> root.biblias_fondo_opacity; changed => { root.sync_estilos(); } }
                                Text { text: round(root.biblias_fondo_opacity * 100) + "%"; color: #3a3a3a; font-size: 9px; font-weight: 700; vertical-alignment: center; min-width: 30px; }
                            }
                        }

                        Rectangle { height: 16px; }
                        Rectangle { height: 1px; background: rgba(255,255,255,0.04); }
                        Rectangle { height: 16px; }

                        // — TEXTO —
                        HorizontalLayout { spacing: 0px; alignment: space-between;
                            VerticalLayout { spacing: 8px; alignment: start;
                                Text { text: "TEXTO"; color: #272727; font-size: 8px; font-weight: 900; letter-spacing: 2px; }
                                HorizontalLayout { spacing: 5px; alignment: start;
                                    // White
                                    Rectangle { width: 28px; height: 28px; border-radius: 14px; background: root.biblias_font_color == #ffffff ? rgba(14,165,233,0.2) : transparent; border-width: 2px; border-color: root.biblias_font_color == #ffffff ? #0ea5e9 : transparent; Rectangle { width: 20px; height: 20px; border-radius: 10px; x: 2px; y: 2px; background: #ffffff; border-width: 1px; border-color: rgba(0,0,0,0.08); } nm-bfc0 := TouchArea { clicked => { root.biblias_font_color = #ffffff; root.sync_estilos(); } } }
                                    // Black
                                    Rectangle { width: 28px; height: 28px; border-radius: 14px; background: root.biblias_font_color == #000000 ? rgba(14,165,233,0.2) : transparent; border-width: 2px; border-color: root.biblias_font_color == #000000 ? #0ea5e9 : transparent; Rectangle { width: 20px; height: 20px; border-radius: 10px; x: 2px; y: 2px; background: #000000; border-width: 1px; border-color: rgba(255,255,255,0.12); } nm-bfc1 := TouchArea { clicked => { root.biblias_font_color = #000000; root.sync_estilos(); } } }
                                    // Amarillo
                                    Rectangle { width: 28px; height: 28px; border-radius: 14px; background: root.biblias_font_color == #fef08a ? rgba(14,165,233,0.2) : transparent; border-width: 2px; border-color: root.biblias_font_color == #fef08a ? #0ea5e9 : transparent; Rectangle { width: 20px; height: 20px; border-radius: 10px; x: 2px; y: 2px; background: #fef08a; } nm-bfc2 := TouchArea { clicked => { root.biblias_font_color = #fef08a; root.sync_estilos(); } } }
                                    // Verde
                                    Rectangle { width: 28px; height: 28px; border-radius: 14px; background: root.biblias_font_color == #86efac ? rgba(14,165,233,0.2) : transparent; border-width: 2px; border-color: root.biblias_font_color == #86efac ? #0ea5e9 : transparent; Rectangle { width: 20px; height: 20px; border-radius: 10px; x: 2px; y: 2px; background: #86efac; } nm-bfc3 := TouchArea { clicked => { root.biblias_font_color = #86efac; root.sync_estilos(); } } }
                                    // Azul
                                    Rectangle { width: 28px; height: 28px; border-radius: 14px; background: root.biblias_font_color == #93c5fd ? rgba(14,165,233,0.2) : transparent; border-width: 2px; border-color: root.biblias_font_color == #93c5fd ? #0ea5e9 : transparent; Rectangle { width: 20px; height: 20px; border-radius: 10px; x: 2px; y: 2px; background: #93c5fd; } nm-bfc4 := TouchArea { clicked => { root.biblias_font_color = #93c5fd; root.sync_estilos(); } } }
                                    // Coral
                                    Rectangle { width: 28px; height: 28px; border-radius: 14px; background: root.biblias_font_color == #fca5a5 ? rgba(14,165,233,0.2) : transparent; border-width: 2px; border-color: root.biblias_font_color == #fca5a5 ? #0ea5e9 : transparent; Rectangle { width: 20px; height: 20px; border-radius: 10px; x: 2px; y: 2px; background: #fca5a5; } nm-bfc5 := TouchArea { clicked => { root.biblias_font_color = #fca5a5; root.sync_estilos(); } } }
                                    // Lila
                                    Rectangle { width: 28px; height: 28px; border-radius: 14px; background: root.biblias_font_color == #d8b4fe ? rgba(14,165,233,0.2) : transparent; border-width: 2px; border-color: root.biblias_font_color == #d8b4fe ? #0ea5e9 : transparent; Rectangle { width: 20px; height: 20px; border-radius: 10px; x: 2px; y: 2px; background: #d8b4fe; } nm-bfc6 := TouchArea { clicked => { root.biblias_font_color = #d8b4fe; root.sync_estilos(); } } }
                                    // Más colores
                                    Rectangle { width: 28px; height: 28px; border-radius: 14px; background: rgba(255,255,255,0.04); border-width: 1px; border-color: rgba(255,255,255,0.09); nm-bfcc := TouchArea { clicked => { root.color_target = "biblias"; root.mostrar_selector_color = true; } } Text { text: "+"; color: #3a3a3a; font-size: 13px; font-weight: 700; horizontal-alignment: center; vertical-alignment: center; } }
                                }
                            }
                            // Tamaño de letra
                            VerticalLayout { spacing: 8px; alignment: start; horizontal-stretch: 0;
                                Text { text: "TAMAÑO"; color: #272727; font-size: 8px; font-weight: 900; letter-spacing: 2px; }
                                HorizontalLayout { spacing: 4px; alignment: start;
                                    Rectangle { width: 30px; height: 28px; border-radius: 6px; background: nm-bsm.has-hover ? rgba(255,255,255,0.07) : rgba(255,255,255,0.03); border-width: 1px; border-color: rgba(255,255,255,0.06); nm-bsm := TouchArea { clicked => { root.biblias_font_scale = max(0.5, root.biblias_font_scale - 0.1); root.sync_font_scale(); } } Text { text: "−"; color: #4b5563; font-size: 14px; horizontal-alignment: center; vertical-alignment: center; } }
                                    Rectangle { width: 52px; height: 28px; border-radius: 6px; background: rgba(255,255,255,0.02); border-width: 1px; border-color: rgba(255,255,255,0.04); Text { text: round(root.biblias_font_scale * 100) + "%"; color: #6b7280; font-size: 10px; font-weight: 700; horizontal-alignment: center; vertical-alignment: center; width: 100%; height: 100%; } }
                                    Rectangle { width: 30px; height: 28px; border-radius: 6px; background: nm-bsp.has-hover ? rgba(255,255,255,0.07) : rgba(255,255,255,0.03); border-width: 1px; border-color: rgba(255,255,255,0.06); nm-bsp := TouchArea { clicked => { root.biblias_font_scale = min(2.0, root.biblias_font_scale + 0.1); root.sync_font_scale(); } } Text { text: "+"; color: #4b5563; font-size: 14px; horizontal-alignment: center; vertical-alignment: center; } }
                                }
                            }
                        }

                        Rectangle { height: 16px; }
                        Rectangle { height: 1px; background: rgba(255,255,255,0.04); }
                        Rectangle { height: 14px; }

                        // — GALERÍA —
                        HorizontalLayout { alignment: space-between;
                            Text { text: "GALERÍA"; color: #272727; font-size: 8px; font-weight: 900; letter-spacing: 2px; vertical-alignment: center; }
                            HorizontalLayout { spacing: 0px;
                                Rectangle { width: 80px; height: 24px; border-top-left-radius: 6px; border-bottom-left-radius: 6px; background: current_gal_tab == "imagenes" ? rgba(14,165,233,0.14) : rgba(255,255,255,0.02); border-width: 1px; border-color: current_gal_tab == "imagenes" ? #0ea5e9 : rgba(255,255,255,0.05); nm-bgi := TouchArea { clicked => { current_gal_tab = "imagenes"; } } Text { text: "Imágenes"; color: current_gal_tab == "imagenes" ? #38bdf8 : #3a3a3a; font-size: 8px; font-weight: 800; horizontal-alignment: center; vertical-alignment: center; width: 100%; height: 100%; } }
                                Rectangle { width: 70px; height: 24px; border-top-right-radius: 6px; border-bottom-right-radius: 6px; background: current_gal_tab == "videos" ? rgba(14,165,233,0.14) : rgba(255,255,255,0.02); border-width: 1px; border-color: current_gal_tab == "videos" ? #0ea5e9 : rgba(255,255,255,0.05); nm-bgv := TouchArea { clicked => { current_gal_tab = "videos"; } } Text { text: "Videos"; color: current_gal_tab == "videos" ? #38bdf8 : #3a3a3a; font-size: 8px; font-weight: 800; horizontal-alignment: center; vertical-alignment: center; width: 100%; height: 100%; } }
                            }
                        }
                        Rectangle { height: 10px; }

                        Rectangle {
                            vertical-stretch: 1; border-radius: 8px; clip: true;
                            if (current_gal_tab == "imagenes") : ScrollView {
                                width: 100%; height: 100%;
                                HorizontalLayout { padding: 2px; spacing: 8px; alignment: start;
                                    Rectangle { width: 92px; height: 64px; border-radius: 8px; border-width: 1px; border-color: rgba(255,255,255,0.06); background: nm-bagi.has-hover ? rgba(255,255,255,0.05) : rgba(255,255,255,0.02); nm-bagi := TouchArea { clicked => { root.agregar_a_galeria("biblias-img"); } } VerticalLayout { alignment: center; spacing: 3px; Text { text: "+"; color: #272727; font-size: 20px; horizontal-alignment: center; } Text { text: "Agregar"; color: #272727; font-size: 8px; horizontal-alignment: center; font-weight: 700; } } }
                                    for img[idx] in root.biblias_image_data : Rectangle { width: 92px; height: 64px; border-radius: 8px; border-width: 2px; border-color: root.biblias_selected_img == idx ? #0ea5e9 : rgba(255,255,255,0.04); clip: true; Image { source: img; width: 100%; height: 100%; image-fit: cover; } TouchArea { clicked => { root.seleccionar_galeria_item("biblias-img", idx); } } Rectangle { width: 16px; height: 16px; x: parent.width - 20px; y: 4px; border-radius: 8px; background: rgba(0,0,0,0.75); TouchArea { clicked => { root.eliminar_galeria_item("biblias-img", idx); } } Text { text: "✕"; color: #f87171; font-size: 8px; horizontal-alignment: center; vertical-alignment: center; font-weight: 900; } } }
                                }
                            }
                            if (current_gal_tab == "videos") : ScrollView {
                                width: 100%; height: 100%;
                                HorizontalLayout { padding: 2px; spacing: 8px; alignment: start;
                                    Rectangle { width: 92px; height: 64px; border-radius: 8px; border-width: 1px; border-color: rgba(255,255,255,0.06); background: nm-bagv.has-hover ? rgba(255,255,255,0.05) : rgba(255,255,255,0.02); nm-bagv := TouchArea { clicked => { root.agregar_a_galeria("biblias-vid"); } } VerticalLayout { alignment: center; spacing: 3px; Text { text: "+"; color: #272727; font-size: 20px; horizontal-alignment: center; } Text { text: "Agregar"; color: #272727; font-size: 8px; horizontal-alignment: center; font-weight: 700; } } }
                                    for vid[idx] in root.biblias_video_names : Rectangle { width: 92px; height: 64px; border-radius: 8px; border-width: 2px; background: #080808; border-color: root.biblias_selected_vid == idx ? #0ea5e9 : rgba(255,255,255,0.04); VerticalLayout { padding-left: 8px; padding-right: 8px; padding-top: 8px; padding-bottom: 6px; alignment: center; spacing: 4px; Rectangle { height: 14px; background: rgba(255,255,255,0.04); border-radius: 3px; Text { text: "MP4"; font-size: 6px; font-weight: 900; color: #272727; horizontal-alignment: center; vertical-alignment: center; width: 100%; height: 100%; } } Text { text: vid; font-size: 7px; color: #3a3a3a; horizontal-alignment: center; vertical-alignment: center; wrap: word-wrap; } } TouchArea { clicked => { root.seleccionar_galeria_item("biblias-vid", idx); } } Rectangle { width: 16px; height: 16px; x: parent.width - 20px; y: 4px; border-radius: 8px; background: rgba(0,0,0,0.75); TouchArea { clicked => { root.eliminar_galeria_item("biblias-vid", idx); } } Text { text: "✕"; color: #f87171; font-size: 8px; horizontal-alignment: center; vertical-alignment: center; font-weight: 900; } } }
                                }
                            }
                        }
                    }

                    // ═══ CANTO TAB ══════════════════════════════════════════
                    if (root.modal_tab == "cantos") : VerticalLayout {
                        padding-left: 22px; padding-right: 22px; padding-top: 18px; padding-bottom: 16px; spacing: 0px;

                        Text { text: "FONDO"; color: #272727; font-size: 8px; font-weight: 900; letter-spacing: 2px; }
                        Rectangle { height: 10px; }
                        HorizontalLayout { spacing: 0px; alignment: space-between;
                            HorizontalLayout { spacing: 6px; alignment: start;
                                Rectangle { width: 44px; height: 32px; border-radius: 7px; background: #000000; border-width: 2px; border-color: root.cantos_bg_type == "negro" ? #0ea5e9 : rgba(255,255,255,0.15); nm-cbn := TouchArea { clicked => { root.cantos_bg_type = "negro"; root.sync_estilos(); } } }
                                Rectangle { width: 44px; height: 32px; border-radius: 7px; background: #ffffff; border-width: 2px; border-color: root.cantos_bg_type == "blanco" ? #0ea5e9 : rgba(0,0,0,0.15); nm-cbb := TouchArea { clicked => { root.cantos_bg_type = "blanco"; root.sync_estilos(); } } }
                                Rectangle { width: 66px; height: 32px; border-radius: 7px; background: root.cantos_bg_type == "imagen" ? rgba(14,165,233,0.14) : rgba(255,255,255,0.03); border-width: 1px; border-color: root.cantos_bg_type == "imagen" ? #0ea5e9 : rgba(255,255,255,0.06); nm-cbi := TouchArea { clicked => { root.cantos_bg_type = "imagen"; root.sync_estilos(); } } Text { text: "Imagen"; font-size: 9px; font-weight: 700; color: root.cantos_bg_type == "imagen" ? #38bdf8 : #3d3d3d; horizontal-alignment: center; vertical-alignment: center; } }
                                Rectangle { width: 62px; height: 32px; border-radius: 7px; background: root.cantos_bg_type == "video" ? rgba(14,165,233,0.14) : rgba(255,255,255,0.03); border-width: 1px; border-color: root.cantos_bg_type == "video" ? #0ea5e9 : rgba(255,255,255,0.06); nm-cbv := TouchArea { clicked => { root.cantos_bg_type = "video"; root.sync_estilos(); } } Text { text: "Video"; font-size: 9px; font-weight: 700; color: root.cantos_bg_type == "video" ? #38bdf8 : #3d3d3d; horizontal-alignment: center; vertical-alignment: center; } }
                            }
                            HorizontalLayout { spacing: 8px; alignment: end;
                                Text { text: "Opacidad"; color: #2d2d2d; font-size: 9px; font-weight: 700; vertical-alignment: center; }
                                Slider { width: 100px; minimum: 0.0; maximum: 1.0; value <=> root.cantos_fondo_opacity; changed => { root.sync_estilos(); } }
                                Text { text: round(root.cantos_fondo_opacity * 100) + "%"; color: #3a3a3a; font-size: 9px; font-weight: 700; vertical-alignment: center; min-width: 30px; }
                            }
                        }

                        Rectangle { height: 16px; }
                        Rectangle { height: 1px; background: rgba(255,255,255,0.04); }
                        Rectangle { height: 16px; }

                        HorizontalLayout { spacing: 0px; alignment: space-between;
                            VerticalLayout { spacing: 8px; alignment: start;
                                Text { text: "TEXTO"; color: #272727; font-size: 8px; font-weight: 900; letter-spacing: 2px; }
                                HorizontalLayout { spacing: 5px; alignment: start;
                                    Rectangle { width: 28px; height: 28px; border-radius: 14px; background: root.cantos_font_color == #ffffff ? rgba(14,165,233,0.2) : transparent; border-width: 2px; border-color: root.cantos_font_color == #ffffff ? #0ea5e9 : transparent; Rectangle { width: 20px; height: 20px; border-radius: 10px; x: 2px; y: 2px; background: #ffffff; border-width: 1px; border-color: rgba(0,0,0,0.08); } nm-cfc0 := TouchArea { clicked => { root.cantos_font_color = #ffffff; root.sync_estilos(); } } }
                                    Rectangle { width: 28px; height: 28px; border-radius: 14px; background: root.cantos_font_color == #000000 ? rgba(14,165,233,0.2) : transparent; border-width: 2px; border-color: root.cantos_font_color == #000000 ? #0ea5e9 : transparent; Rectangle { width: 20px; height: 20px; border-radius: 10px; x: 2px; y: 2px; background: #000000; border-width: 1px; border-color: rgba(255,255,255,0.12); } nm-cfc1 := TouchArea { clicked => { root.cantos_font_color = #000000; root.sync_estilos(); } } }
                                    Rectangle { width: 28px; height: 28px; border-radius: 14px; background: root.cantos_font_color == #fef08a ? rgba(14,165,233,0.2) : transparent; border-width: 2px; border-color: root.cantos_font_color == #fef08a ? #0ea5e9 : transparent; Rectangle { width: 20px; height: 20px; border-radius: 10px; x: 2px; y: 2px; background: #fef08a; } nm-cfc2 := TouchArea { clicked => { root.cantos_font_color = #fef08a; root.sync_estilos(); } } }
                                    Rectangle { width: 28px; height: 28px; border-radius: 14px; background: root.cantos_font_color == #86efac ? rgba(14,165,233,0.2) : transparent; border-width: 2px; border-color: root.cantos_font_color == #86efac ? #0ea5e9 : transparent; Rectangle { width: 20px; height: 20px; border-radius: 10px; x: 2px; y: 2px; background: #86efac; } nm-cfc3 := TouchArea { clicked => { root.cantos_font_color = #86efac; root.sync_estilos(); } } }
                                    Rectangle { width: 28px; height: 28px; border-radius: 14px; background: root.cantos_font_color == #93c5fd ? rgba(14,165,233,0.2) : transparent; border-width: 2px; border-color: root.cantos_font_color == #93c5fd ? #0ea5e9 : transparent; Rectangle { width: 20px; height: 20px; border-radius: 10px; x: 2px; y: 2px; background: #93c5fd; } nm-cfc4 := TouchArea { clicked => { root.cantos_font_color = #93c5fd; root.sync_estilos(); } } }
                                    Rectangle { width: 28px; height: 28px; border-radius: 14px; background: root.cantos_font_color == #fca5a5 ? rgba(14,165,233,0.2) : transparent; border-width: 2px; border-color: root.cantos_font_color == #fca5a5 ? #0ea5e9 : transparent; Rectangle { width: 20px; height: 20px; border-radius: 10px; x: 2px; y: 2px; background: #fca5a5; } nm-cfc5 := TouchArea { clicked => { root.cantos_font_color = #fca5a5; root.sync_estilos(); } } }
                                    Rectangle { width: 28px; height: 28px; border-radius: 14px; background: root.cantos_font_color == #d8b4fe ? rgba(14,165,233,0.2) : transparent; border-width: 2px; border-color: root.cantos_font_color == #d8b4fe ? #0ea5e9 : transparent; Rectangle { width: 20px; height: 20px; border-radius: 10px; x: 2px; y: 2px; background: #d8b4fe; } nm-cfc6 := TouchArea { clicked => { root.cantos_font_color = #d8b4fe; root.sync_estilos(); } } }
                                    Rectangle { width: 28px; height: 28px; border-radius: 14px; background: rgba(255,255,255,0.04); border-width: 1px; border-color: rgba(255,255,255,0.09); nm-cfcc := TouchArea { clicked => { root.color_target = "cantos"; root.mostrar_selector_color = true; } } Text { text: "+"; color: #3a3a3a; font-size: 13px; font-weight: 700; horizontal-alignment: center; vertical-alignment: center; } }
                                }
                            }
                            VerticalLayout { spacing: 8px; alignment: start; horizontal-stretch: 0;
                                Text { text: "TAMAÑO"; color: #272727; font-size: 8px; font-weight: 900; letter-spacing: 2px; }
                                HorizontalLayout { spacing: 4px; alignment: start;
                                    Rectangle { width: 30px; height: 28px; border-radius: 6px; background: nm-csm.has-hover ? rgba(255,255,255,0.07) : rgba(255,255,255,0.03); border-width: 1px; border-color: rgba(255,255,255,0.06); nm-csm := TouchArea { clicked => { root.cantos_font_scale = max(0.5, root.cantos_font_scale - 0.1); root.sync_font_scale(); } } Text { text: "−"; color: #4b5563; font-size: 14px; horizontal-alignment: center; vertical-alignment: center; } }
                                    Rectangle { width: 52px; height: 28px; border-radius: 6px; background: rgba(255,255,255,0.02); border-width: 1px; border-color: rgba(255,255,255,0.04); Text { text: round(root.cantos_font_scale * 100) + "%"; color: #6b7280; font-size: 10px; font-weight: 700; horizontal-alignment: center; vertical-alignment: center; width: 100%; height: 100%; } }
                                    Rectangle { width: 30px; height: 28px; border-radius: 6px; background: nm-csp.has-hover ? rgba(255,255,255,0.07) : rgba(255,255,255,0.03); border-width: 1px; border-color: rgba(255,255,255,0.06); nm-csp := TouchArea { clicked => { root.cantos_font_scale = min(2.0, root.cantos_font_scale + 0.1); root.sync_font_scale(); } } Text { text: "+"; color: #4b5563; font-size: 14px; horizontal-alignment: center; vertical-alignment: center; } }
                                }
                            }
                        }

                        Rectangle { height: 16px; }
                        Rectangle { height: 1px; background: rgba(255,255,255,0.04); }
                        Rectangle { height: 14px; }

                        HorizontalLayout { alignment: space-between;
                            Text { text: "GALERÍA"; color: #272727; font-size: 8px; font-weight: 900; letter-spacing: 2px; vertical-alignment: center; }
                            HorizontalLayout { spacing: 0px;
                                Rectangle { width: 80px; height: 24px; border-top-left-radius: 6px; border-bottom-left-radius: 6px; background: current_gal_tab == "imagenes" ? rgba(14,165,233,0.14) : rgba(255,255,255,0.02); border-width: 1px; border-color: current_gal_tab == "imagenes" ? #0ea5e9 : rgba(255,255,255,0.05); nm-cgi := TouchArea { clicked => { current_gal_tab = "imagenes"; } } Text { text: "Imágenes"; color: current_gal_tab == "imagenes" ? #38bdf8 : #3a3a3a; font-size: 8px; font-weight: 800; horizontal-alignment: center; vertical-alignment: center; width: 100%; height: 100%; } }
                                Rectangle { width: 70px; height: 24px; border-top-right-radius: 6px; border-bottom-right-radius: 6px; background: current_gal_tab == "videos" ? rgba(14,165,233,0.14) : rgba(255,255,255,0.02); border-width: 1px; border-color: current_gal_tab == "videos" ? #0ea5e9 : rgba(255,255,255,0.05); nm-cgv := TouchArea { clicked => { current_gal_tab = "videos"; } } Text { text: "Videos"; color: current_gal_tab == "videos" ? #38bdf8 : #3a3a3a; font-size: 8px; font-weight: 800; horizontal-alignment: center; vertical-alignment: center; width: 100%; height: 100%; } }
                            }
                        }
                        Rectangle { height: 10px; }

                        Rectangle {
                            vertical-stretch: 1; border-radius: 8px; clip: true;
                            if (current_gal_tab == "imagenes") : ScrollView {
                                width: 100%; height: 100%;
                                HorizontalLayout { padding: 2px; spacing: 8px; alignment: start;
                                    Rectangle { width: 92px; height: 64px; border-radius: 8px; border-width: 1px; border-color: rgba(255,255,255,0.06); background: nm-cagi.has-hover ? rgba(255,255,255,0.05) : rgba(255,255,255,0.02); nm-cagi := TouchArea { clicked => { root.agregar_a_galeria("cantos-img"); } } VerticalLayout { alignment: center; spacing: 3px; Text { text: "+"; color: #272727; font-size: 20px; horizontal-alignment: center; } Text { text: "Agregar"; color: #272727; font-size: 8px; horizontal-alignment: center; font-weight: 700; } } }
                                    for img[idx] in root.cantos_image_data : Rectangle { width: 92px; height: 64px; border-radius: 8px; border-width: 2px; border-color: root.cantos_selected_img == idx ? #0ea5e9 : rgba(255,255,255,0.04); clip: true; Image { source: img; width: 100%; height: 100%; image-fit: cover; } TouchArea { clicked => { root.seleccionar_galeria_item("cantos-img", idx); } } Rectangle { width: 16px; height: 16px; x: parent.width - 20px; y: 4px; border-radius: 8px; background: rgba(0,0,0,0.75); TouchArea { clicked => { root.eliminar_galeria_item("cantos-img", idx); } } Text { text: "✕"; color: #f87171; font-size: 8px; horizontal-alignment: center; vertical-alignment: center; font-weight: 900; } } }
                                }
                            }
                            if (current_gal_tab == "videos") : ScrollView {
                                width: 100%; height: 100%;
                                HorizontalLayout { padding: 2px; spacing: 8px; alignment: start;
                                    Rectangle { width: 92px; height: 64px; border-radius: 8px; border-width: 1px; border-color: rgba(255,255,255,0.06); background: nm-cagv.has-hover ? rgba(255,255,255,0.05) : rgba(255,255,255,0.02); nm-cagv := TouchArea { clicked => { root.agregar_a_galeria("cantos-vid"); } } VerticalLayout { alignment: center; spacing: 3px; Text { text: "+"; color: #272727; font-size: 20px; horizontal-alignment: center; } Text { text: "Agregar"; color: #272727; font-size: 8px; horizontal-alignment: center; font-weight: 700; } } }
                                    for vid[idx] in root.cantos_video_names : Rectangle { width: 92px; height: 64px; border-radius: 8px; border-width: 2px; background: #080808; border-color: root.cantos_selected_vid == idx ? #0ea5e9 : rgba(255,255,255,0.04); VerticalLayout { padding-left: 8px; padding-right: 8px; padding-top: 8px; padding-bottom: 6px; alignment: center; spacing: 4px; Rectangle { height: 14px; background: rgba(255,255,255,0.04); border-radius: 3px; Text { text: "MP4"; font-size: 6px; font-weight: 900; color: #272727; horizontal-alignment: center; vertical-alignment: center; width: 100%; height: 100%; } } Text { text: vid; font-size: 7px; color: #3a3a3a; horizontal-alignment: center; vertical-alignment: center; wrap: word-wrap; } } TouchArea { clicked => { root.seleccionar_galeria_item("cantos-vid", idx); } } Rectangle { width: 16px; height: 16px; x: parent.width - 20px; y: 4px; border-radius: 8px; background: rgba(0,0,0,0.75); TouchArea { clicked => { root.eliminar_galeria_item("cantos-vid", idx); } } Text { text: "✕"; color: #f87171; font-size: 8px; horizontal-alignment: center; vertical-alignment: center; font-weight: 900; } } }
                                }
                            }
                        }
                    }
                }
            }
        }
    }

    // ══════════════════════════════════════════════════════════════
    //  MENÚ CONTEXTUAL DE CANTO (sin cambios)
    // ══════════════════════════════════════════════════════════════
    if (root.mostrar_menu_canto) : Rectangle {
        width: 100%; height: 100%; background: transparent;
        touch-dismiss := TouchArea { clicked => { root.mostrar_menu_canto = false; } }
        Rectangle {
            x: root.menu_x; y: root.menu_y;
            width: 185px; height: 114px;
            background: #1e1e1e; border-radius: 8px; border-width: 1px; border-color: #374151;
            drop-shadow-color: rgba(0,0,0,0.6); drop-shadow-blur: 16px;
            touch-block := TouchArea {}
            VerticalLayout {
                padding: 4px; spacing: 0px;
                Rectangle { height: 34px; border-radius: 6px; background: touch-add.has-hover ? rgba(14, 165, 233, 0.15) : transparent; touch-add := TouchArea { clicked => { root.mostrar_menu_canto = false; root.abrir_formulario_nuevo(); } } HorizontalLayout { padding-left: 12px; spacing: 10px; Text { text: "+"; color: #0ea5e9; font-size: 15px; font-weight: 900; vertical-alignment: center; } Text { text: "Agregar canto"; color: #e5e7eb; font-size: 11px; font-weight: 600; vertical-alignment: center; } } }
                Rectangle { height: 34px; border-radius: 6px; background: touch-edit.has-hover ? rgba(14, 165, 233, 0.15) : transparent; touch-edit := TouchArea { clicked => { root.mostrar_menu_canto = false; root.abrir_formulario_editar(root.menu_canto_id, root.menu_canto_titulo); } } HorizontalLayout { padding-left: 12px; spacing: 10px; Text { text: "✎"; color: #9ca3af; font-size: 13px; vertical-alignment: center; } Text { text: "Editar canto"; color: #e5e7eb; font-size: 11px; font-weight: 600; vertical-alignment: center; } } }
                Rectangle { height: 1px; background: #2d2d2d; }
                Rectangle { height: 34px; border-radius: 6px; background: touch-del.has-hover ? rgba(220, 38, 38, 0.15) : transparent; touch-del := TouchArea { clicked => { root.mostrar_menu_canto = false; root.confirmar_eliminar_canto(root.menu_canto_id, root.menu_canto_titulo); } } HorizontalLayout { padding-left: 12px; spacing: 10px; Text { text: "✕"; color: #f87171; font-size: 12px; font-weight: 900; vertical-alignment: center; } Text { text: "Eliminar canto"; color: #f87171; font-size: 11px; font-weight: 600; vertical-alignment: center; } } }
            }
        }
    }

    // ══════════════════════════════════════════════════════════════
    //  MODAL SELECTOR DE COLOR (sin cambios)
    // ══════════════════════════════════════════════════════════════
    if (root.mostrar_selector_color) : Rectangle {
        width: 100%; height: 100%; background: rgba(0,0,0,0.65);
        touch-bg-color := TouchArea { clicked => { root.mostrar_selector_color = false; } }
        Rectangle {
            width: 330px; height: 210px;
            background: #27272a; border-radius: 8px; border-width: 1px; border-color: #3f3f46;
            drop-shadow-color: rgba(0,0,0,0.5); drop-shadow-blur: 20px;
            touch-block-color := TouchArea {}
            VerticalLayout {
                padding: 16px; spacing: 16px;
                HorizontalLayout {
                    Text { text: "🎨  Seleccionar Color"; color: white; font-weight: 800; font-size: 12px; vertical-alignment: center; horizontal-stretch: 1; }
                    Rectangle { width: 24px; height: 24px; border-radius: 4px; background: touch-close-col.has-hover ? rgba(255,255,255,0.1) : transparent; touch-close-col := TouchArea { clicked => { root.mostrar_selector_color = false; } } Text { text: "✕"; color: #9ca3af; font-weight: 900; horizontal-alignment: center; vertical-alignment: center; } }
                }
                VerticalLayout {
                    spacing: 8px; alignment: center;
                    for row in root.paleta_colores : HorizontalLayout {
                        spacing: 8px; alignment: center;
                        for c in row : Rectangle {
                            width: 28px; height: 28px; border-radius: 6px; background: c;
                            border-width: 1px; border-color: rgba(255,255,255,0.1);
                            touch-c := TouchArea {
                                clicked => {
                                    if (root.color_target == "biblias") { root.biblias_custom_color = c; root.biblias_font_color = c; }
                                    else { root.cantos_custom_color = c; root.cantos_font_color = c; }
                                    root.sync_estilos(); root.mostrar_selector_color = false;
                                }
                            }
                        }
                    }
                }
            }
        }
    }

    // ══════════════════════════════════════════════════════════════
    //  MODAL CONFIRMACIÓN ELIMINAR (sin cambios)
    // ══════════════════════════════════════════════════════════════
    if (root.mostrar_confirmar_eliminar) : Rectangle {
        width: 100%; height: 100%; background: rgba(0,0,0,0.65);
        touch-bg-elim := TouchArea { clicked => { root.mostrar_confirmar_eliminar = false; } }
        Rectangle {
            width: 360px; height: 170px;
            background: #111111; border-radius: 12px; border-width: 1px; border-color: #27272a;
            drop-shadow-color: rgba(0,0,0,0.5); drop-shadow-blur: 20px;
            touch-block-elim := TouchArea {}
            VerticalLayout {
                padding: 28px; spacing: 14px;
                Text { text: "Eliminar canto"; color: white; font-size: 14px; font-weight: 900; horizontal-alignment: center; }
                Text { text: "\"" + root.menu_canto_titulo + "\" sera eliminado permanentemente."; color: #6b7280; font-size: 11px; horizontal-alignment: center; wrap: word-wrap; }
                HorizontalLayout { spacing: 12px; alignment: center;
                    Rectangle { width: 110px; height: 36px; border-radius: 6px; background: touch-cancel.has-hover ? #27272a : #1f1f1f; border-width: 1px; border-color: #374151; touch-cancel := TouchArea { clicked => { root.mostrar_confirmar_eliminar = false; } } Text { text: "Cancelar"; color: #9ca3af; font-size: 11px; font-weight: 700; horizontal-alignment: center; vertical-alignment: center; } }
                    Rectangle { width: 110px; height: 36px; border-radius: 6px; background: touch-confirm.has-hover ? #b91c1c : #dc2626; touch-confirm := TouchArea { clicked => { root.eliminar_canto(root.menu_canto_id); root.mostrar_confirmar_eliminar = false; } } Text { text: "Eliminar"; color: white; font-size: 11px; font-weight: 700; horizontal-alignment: center; vertical-alignment: center; } }
                }
            }
        }
    }

    // ══════════════════════════════════════════════════════════════
    //  MODAL FORMULARIO AGREGAR / EDITAR (sin cambios)
    // ══════════════════════════════════════════════════════════════
    if (root.mostrar_formulario) : Rectangle {
        width: 100%; height: 100%; background: rgba(0,0,0,0.65);
        VerticalLayout {
            alignment: center;
            HorizontalLayout {
                alignment: center;
                Rectangle {
                    width: 520px; height: 500px;
                    background: #111111; border-radius: 12px; border-width: 1px; border-color: #27272a;
                    drop-shadow-color: rgba(0,0,0,0.5); drop-shadow-blur: 20px;
                    VerticalLayout {
                        padding: 24px; spacing: 14px;
                        HorizontalLayout { alignment: space-between; height: 32px; Text { text: root.form_id == -1 ? "AGREGAR CANTO" : "EDITAR CANTO"; color: #0ea5e9; font-size: 13px; font-weight: 900; vertical-alignment: center; horizontal-stretch: 1; } Rectangle { width: 28px; height: 28px; border-radius: 6px; background: touch-close-form.has-hover ? rgba(255,255,255,0.1) : transparent; touch-close-form := TouchArea { clicked => { root.mostrar_formulario = false; } } Text { text: "✕"; color: #9ca3af; font-size: 13px; horizontal-alignment: center; vertical-alignment: center; } } }
                        Rectangle { height: 1px; background: rgba(255,255,255,0.07); }
                        VerticalLayout { spacing: 6px; height: 62px; Text { text: "TÍTULO"; color: #6b7280; font-size: 9px; font-weight: 800; letter-spacing: 0.5px; height: 16px; } Rectangle { height: 38px; border-radius: 6px; background: #1f1f1f; border-width: 1px; border-color: rgba(255,255,255,0.1); TextInput { x: 12px; width: parent.width - 24px; height: 100%; text <=> root.form_titulo; color: #f3f4f6; font-size: 12px; vertical-alignment: center; } } }
                        VerticalLayout { vertical-stretch: 1; spacing: 6px; Text { text: "LETRA  (separa estrofas con una línea vacía)"; color: #6b7280; font-size: 9px; font-weight: 800; letter-spacing: 0.5px; height: 16px; } Rectangle { vertical-stretch: 1; border-radius: 6px; background: #1f1f1f; border-width: 1px; border-color: rgba(255,255,255,0.1); TextEdit { width: 100%; height: 100%; text <=> root.form_letra; font-size: 12px; } } }
                        HorizontalLayout { alignment: end; spacing: 12px; height: 38px;
                            Rectangle { width: 110px; height: 38px; border-radius: 6px; background: touch-cancel2.has-hover ? #27272a : #1f1f1f; border-width: 1px; border-color: #374151; touch-cancel2 := TouchArea { clicked => { root.mostrar_formulario = false; } } Text { text: "Cancelar"; color: #9ca3af; font-size: 11px; font-weight: 700; horizontal-alignment: center; vertical-alignment: center; } }
                            Rectangle { width: 110px; height: 38px; border-radius: 6px; background: touch-save.has-hover ? #0284c7 : #0ea5e9; touch-save := TouchArea { clicked => { root.guardar_canto(root.form_id, root.form_titulo, root.form_letra); root.mostrar_formulario = false; } } Text { text: "Guardar"; color: white; font-size: 11px; font-weight: 700; horizontal-alignment: center; vertical-alignment: center; } }
                        }
                    }
                }
            }
        }
    }
}